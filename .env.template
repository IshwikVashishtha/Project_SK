# ─────────────────────────────────────────────
# DeepAgent  •  .env template
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# ── Ollama (local) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Per-agent LLM overrides (optional) ────────
# ORCHESTRATOR_PROVIDER=ollama
# ORCHESTRATOR_MODEL=gemma2:2b
# RESEARCH_PROVIDER=ollama
# RESEARCH_MODEL=gemma2:2b
# MEDIA_PROVIDER=ollama
# MEDIA_MODEL=phi3
# DATA_PROVIDER=ollama
# DATA_MODEL=phi3
# SYSTEM_PROVIDER=ollama
# SYSTEM_MODEL=phi3
# SUMMARIZER_PROVIDER=ollama
# SUMMARIZER_MODEL=phi3

# ── Cloud LLM API keys (use if not using Ollama) ─
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROQ_API_KEY=...

# ── Tool API keys ──────────────────────────────
SERPAPI_API_KEY=your_serpapi_key_here
WEATHER_API_KEY=your_openweathermap_key_here

# ── Memory ────────────────────────────────────
MEMORY_DIR=memory_store
BUFFER_WINDOW_SIZE=6
SUMMARY_THRESHOLD=10

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── WhatsApp (Meta Cloud API) ─────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=deepagent